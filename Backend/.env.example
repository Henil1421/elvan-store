# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://<your-project-id>.supabase.co
SUPABASE_PUBLISH_KEY=<your-supabase-anon-key>

# ─── Cache ────────────────────────────────────────────────────────────────────
# Time-to-live for the in-memory product cache (seconds). Default: 300 (5 min)
CACHE_TTL=300

# ─── Real-time ────────────────────────────────────────────────────────────────
# Set to "false" to disable Supabase real-time cache invalidation
ENABLE_REALTIME=true

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
FRONTEND_ORIGIN=https://ui.elvan.site
